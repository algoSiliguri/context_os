{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-os.local/schemas/permission-manifest.schema.json",
  "title": "Agent OS Permission Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["component_id", "version", "capabilities"],
  "properties": {
    "component_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "scope"],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["fs.read", "fs.write", "tool.exec", "memory.write", "net.access"]
          },
          "scope": {
            "type": "array",
            "items": {
              "type": "string",
              "not": { "const": "*" }
            }
          },
          "ttl_seconds": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
